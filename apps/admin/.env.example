# Must match apps/api JWT_SECRET (used by middleware to verify the cookie)
JWT_SECRET=change-me-to-a-long-random-string

# Used by Next.js Edge middleware (NEXT_PUBLIC vars are inlined)
NEXT_PUBLIC_JWT_SECRET=change-me-to-a-long-random-string

# Express API base URL (server-side only for login proxy)
API_URL=http://localhost:4000
