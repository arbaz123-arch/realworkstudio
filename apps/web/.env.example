# RealWorkStudio Web App Environment Configuration
# Copy this file to .env.local and update values for your environment

# =============================================================================
# API Configuration
# =============================================================================
# Backend API URL (server-side only)
# This is used by the web app to communicate with the backend API
# Default: http://localhost:4000 (for local development)
# Production: https://api.realworkstudio.com (or your API domain)
API_URL=http://localhost:4000

# =============================================================================
# Public Site Configuration
# =============================================================================
# Public site URL for SEO (sitemap, robots.txt, metadata)
# This must be prefixed with NEXT_PUBLIC_ to be accessible in browser
# Default: https://realworkstudio.com
NEXT_PUBLIC_SITE_URL=https://realworkstudio.com

# =============================================================================
# Optional: Analytics & Monitoring
# =============================================================================
# Uncomment and configure if needed
# NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# =============================================================================
# Optional: Feature Flags
# =============================================================================
# Uncomment to enable specific features
# NEXT_PUBLIC_ENABLE_BLOG=true
# NEXT_PUBLIC_ENABLE_ANALYTICS=true
